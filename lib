    local function updateArrows()
        local canvas = TabsScroll.CanvasPosition.X
        local maxScroll = TabsScroll.AbsoluteCanvasSize.X - TabsScroll.AbsoluteSize.X

        local showLeft  = canvas > 1
        local showRight = maxScroll > 1 and canvas < maxScroll - 1

        ArrowLeft.Visible  = showLeft
        FadeLeft.Visible   = showLeft
        ArrowRight.Visible = showRight
        FadeRight.Visible  = showRight

        local leftOffset  = showLeft  and 22 or 4
        local rightOffset = showRight and 22 or 4
        TabsScroll.Position = UDim2.new(0, leftOffset, 0, 2)
        TabsScroll.Size     = UDim2.new(1, -(leftOffset + rightOffset), 1, -2)
    end

