    KeybindBtn.Text = "[" .. toggleKey.Name .. "]"
    KeybindBtn.TextColor3 = currentTheme.TextColor
    KeybindBtn.TextTransparency = 0.3
    KeybindBtn.TextSize = 11
    KeybindBtn.AutoButtonColor = false
    KeybindBtn.ZIndex = 3

    Instance.new("UICorner", KeybindBtn).CornerRadius = UDim.new(0, 4)
    local KBBStroke = Instance.new("UIStroke", KeybindBtn)
    KBBStroke.Color = Color3.fromRGB(255,255,255); KBBStroke.Transparency = 0.85; KBBStroke.Thickness = 1

    KeybindBtn.MouseEnter:Connect(function()
        if not listeningForKey then Tween(KeybindBtn, {BackgroundTransparency=0.25}, 0.1) end
    end)
    KeybindBtn.MouseLeave:Connect(function()
        if not listeningForKey then Tween(KeybindBtn, {BackgroundTransparency=0.5}, 0.1) end
    end)
    KeybindBtn.MouseButton1Click:Connect(function()
        if listeningForKey then return end
        listeningForKey = true
        KeybindBtn.Text = "..."
        Tween(KeybindBtn, {BackgroundColor3=currentTheme.SchemeColor, BackgroundTransparency=0.1, TextTransparency=0}, 0.15)
    end)

    local Close = Instance.new("ImageButton")
    Close.Parent = Header
    Close.BackgroundTransparency = 1
    Close.AnchorPoint = Vector2.new(1, 0.5)
    Close.Position = UDim2.new(1, -6, 0.5, 0)
    Close.Size = UDim2.new(0, 18, 0, 18)
    Close.Image = "rbxassetid://3926305904"
    Close.ImageRectOffset = Vector2.new(284, 4)
    Close.ImageRectSize = Vector2.new(24, 24)
    Close.ImageColor3 = currentTheme.TextColor
    Close.ZIndex = 3
    Close.MouseButton1Click:Connect(function()
        Tween(Main, {Size = UDim2.new(0,0,0,0)})
        task.wait(0.3)
        ScreenGui:Destroy()
    end)

    local TabBar = Instance.new("Frame")
    TabBar.Name = "TabBar"; TabBar.Parent = Main
    TabBar.BackgroundColor3 = currentTheme.Header; TabBar.BackgroundTransparency = 0.55
    TabBar.Position = UDim2.new(0,0,0,28); TabBar.Size = UDim2.new(1,0,0,30)
    TabBar.ClipsDescendants = true; TabBar.ZIndex = 2
    local TBStroke = Instance.new("UIStroke", TabBar)
    TBStroke.Color = Color3.fromRGB(255,255,255); TBStroke.Transparency = 0.85; TBStroke.Thickness = 1; TBStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    local TabsHolder = Instance.new("Frame")
    TabsHolder.Name = "TabsHolder"; TabsHolder.Parent = TabBar
    TabsHolder.BackgroundTransparency = 1; TabsHolder.Position = UDim2.new(0,4,0,2)
    TabsHolder.Size = UDim2.new(1,-8,1,-2); TabsHolder.ZIndex = 3
    local TabsList = Instance.new("UIListLayout", TabsHolder)
    TabsList.Padding = UDim.new(0,4); TabsList.SortOrder = Enum.SortOrder.LayoutOrder
    TabsList.FillDirection = Enum.FillDirection.Horizontal; TabsList.VerticalAlignment = Enum.VerticalAlignment.Center

    local Content = Instance.new("Frame")
    Content.Name = "Content"; Content.Parent = Main
    Content.BackgroundTransparency = 1; Content.Position = UDim2.new(0,0,0,58)
    Content.Size = UDim2.new(1,0,1,-58); Content.ZIndex = 2

    local Minimized = false

    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if listeningForKey then
            if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
            local ignored = {
                Enum.KeyCode.LeftShift, Enum.KeyCode.RightShift,
                Enum.KeyCode.LeftControl, Enum.KeyCode.RightControl,
                Enum.KeyCode.LeftAlt, Enum.KeyCode.RightAlt, Enum.KeyCode.Unknown,
            }
            local keyCode = input.KeyCode; local isIgnored = false
            for _,k in ipairs(ignored) do if keyCode==k then isIgnored=true break end end
            if isIgnored then return end
            toggleKey = keyCode; listeningForKey = false
            KeybindBtn.Text = "["..keyCode.Name.."]"
            Tween(KeybindBtn, {BackgroundColor3=currentTheme.ElementColor, BackgroundTransparency=0.5, TextTransparency=0.3}, 0.15)
            saveKeybind(keyCode)
            return
        end
        if gameProcessed then return end
        if input.KeyCode == toggleKey then
            Minimized = not Minimized
            if Minimized then Tween(Main, {Size=UDim2.new(0,0,0,0)})
            else Tween(Main, {Size=UDim2.new(0,500,0,370)}) end
        end
    end)

    SimpleKavo:DraggingEnabled(Header, Main)

    local tabsOrder = {}
    local currentTab = nil

    local function recalcTabWidths()
        local count = #tabsOrder
        if count == 0 then return end
        local totalPadding = (count-1)*4
        local availableWidth = TabsHolder.AbsoluteSize.X - totalPadding
        local tabWidth = math.floor(availableWidth/count)
        for _,tab in ipairs(tabsOrder) do
            tab.button.Size = UDim2.new(0, tabWidth, 0, 24)
        end
    end
    TabsHolder:GetPropertyChangedSignal("AbsoluteSize"):Connect(recalcTabWidths)

    local function updateTheme(newThemeName)
        if not Themes[newThemeName] then return end
        currentTheme = Themes[newThemeName]
        Main.BackgroundColor3    = currentTheme.Background
        Header.BackgroundColor3  = currentTheme.Header
        TabBar.BackgroundColor3  = currentTheme.Header
        Title.TextColor3         = currentTheme.TextColor
        KeybindBtn.TextColor3    = currentTheme.TextColor
        KeybindBtn.BackgroundColor3 = currentTheme.ElementColor
        for _,tab in pairs(TabsHolder:GetChildren()) do
            if tab:IsA("TextButton") then
                tab.TextColor3       = currentTheme.TextColor
                tab.BackgroundColor3 = (tab == currentTab) and currentTheme.SchemeColor or currentTheme.ElementColor
            end
        end
        local function updateContent(frame)
            for _,child in pairs(frame:GetChildren()) do
                if child:IsA("TextLabel") then child.TextColor3 = currentTheme.TextColor
                elseif child:IsA("TextButton") then
                    child.TextColor3 = currentTheme.TextColor
                    if child.Name ~= "Fill" then
                        child.BackgroundColor3 = (child.BackgroundColor3==currentTheme.SchemeColor) and currentTheme.SchemeColor or currentTheme.ElementColor
                    else child.BackgroundColor3 = currentTheme.SchemeColor end
                elseif child:IsA("TextBox") then
                    child.TextColor3 = currentTheme.TextColor; child.BackgroundColor3 = currentTheme.ElementColor
                elseif child:IsA("Frame") then
                    if child.Name=="Line" then child.BackgroundColor3 = currentTheme.SchemeColor
                    elseif child.Name=="Bar" then child.BackgroundColor3 = currentTheme.ElementColor
                    elseif child.Name=="Fill" then child.BackgroundColor3 = currentTheme.SchemeColor end
                elseif child:IsA("ScrollingFrame") then
                    child.ScrollBarImageColor3 = currentTheme.SchemeColor
                end
                updateContent(child)
            end
        end
        for _,tab in pairs(tabsOrder) do updateContent(tab.content) end
    end

    function SimpleKavo:AddTab(name)
        local TabButton = Instance.new("TextButton")
        TabButton.Name = name; TabButton.Parent = TabsHolder
        TabButton.BackgroundColor3 = currentTheme.ElementColor; TabButton.BackgroundTransparency = 0.4
        TabButton.Size = UDim2.new(0,90,0,24); TabButton.Font = Enum.Font.GothamSemibold
        TabButton.Text = name; TabButton.TextColor3 = currentTheme.TextColor
        TabButton.TextSize = 13; TabButton.AutoButtonColor = false
        TabButton.LayoutOrder = #tabsOrder+1; TabButton.ZIndex = 4
        Instance.new("UICorner", TabButton).CornerRadius = UDim.new(0,5)

        local ActiveLine = Instance.new("Frame", TabButton)
        ActiveLine.Name = "ActiveLine"; ActiveLine.BackgroundColor3 = currentTheme.SchemeColor
        ActiveLine.BorderSizePixel = 0; ActiveLine.AnchorPoint = Vector2.new(0,1)
        ActiveLine.Position = UDim2.new(0,0,1,0); ActiveLine.Size = UDim2.new(0,0,0,2); ActiveLine.ZIndex = 5

        local TabContent = Instance.new("ScrollingFrame")
