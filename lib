        TabContent.BackgroundTransparency = 1; TabContent.Size = UDim2.new(1,0,1,0)
        TabContent.Visible = false; TabContent.ScrollBarThickness = 4
        TabContent.ScrollBarImageColor3 = currentTheme.SchemeColor
        TabContent.CanvasSize = UDim2.new(0,0,0,0)
        TabContent.AutomaticCanvasSize = Enum.AutomaticSize.Y; TabContent.ZIndex = 3
