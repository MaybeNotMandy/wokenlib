                    if states[optName] == nil then return end
                    states[optName] = value
                    if rows[optName] then rows[optName].updateVisual(value) end
                    if callback then callback(optName, value, states) end
                end

                function methods:Get(optName)
                    if optName then return states[optName] end
                    local copy = {}
                    for k, v in pairs(states) do copy[k] = v end
                    return copy
                end

                return methods
            end

