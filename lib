                CPRow.Font = Enum.Font.Gotham; CPRow.Text = name
                CPRow.TextColor3 = currentTheme.TextColor; CPRow.TextSize = 14
                CPRow.TextXAlignment = Enum.TextXAlignment.Left
                CPRow.AutoButtonColor = false; CPRow.ZIndex = 6
                Instance.new("UICorner", CPRow).CornerRadius = UDim.new(0,4)
                local CPPad = Instance.new("UIPadding", CPRow); CPPad.PaddingLeft = UDim.new(0,10)

                local CPPreview = Instance.new("Frame", CPRow)
                CPPreview.AnchorPoint = Vector2.new(1,0.5); CPPreview.Position = UDim2.new(1,-10,0.5,0)
                CPPreview.Size = UDim2.fromOffset(20,20); CPPreview.BackgroundColor3 = currentColor
                CPPreview.BorderSizePixel = 0; CPPreview.ZIndex = 7
                Instance.new("UICorner", CPPreview).CornerRadius = UDim.new(1,0)
                local CPPStroke = Instance.new("UIStroke", CPPreview)
                CPPStroke.Color = Color3.fromRGB(255,255,255); CPPStroke.Transparency = 0.6; CPPStroke.Thickness = 1.5

                local function colorToHex(c)
                    return string.format("#%02X%02X%02X", math.floor(c.R*255), math.floor(c.G*255), math.floor(c.B*255))
                end
                local HexLabel = Instance.new("TextLabel", CPRow)
                HexLabel.BackgroundTransparency = 1; HexLabel.Font = Enum.Font.Gotham
                HexLabel.Text = colorToHex(currentColor); HexLabel.TextColor3 = currentTheme.TextColor
                HexLabel.TextTransparency = 0.4; HexLabel.TextSize = 11
                HexLabel.AnchorPoint = Vector2.new(1,0.5); HexLabel.Position = UDim2.new(1,-36,0.5,0)
                HexLabel.Size = UDim2.fromOffset(60,20); HexLabel.TextXAlignment = Enum.TextXAlignment.Right; HexLabel.ZIndex = 7

                CPRow.MouseEnter:Connect(function()
                    Tween(CPRow,{BackgroundColor3=Color3.fromRGB(
                        math.clamp(currentTheme.ElementColor.R*255+20,0,255),
                        math.clamp(currentTheme.ElementColor.G*255+20,0,255),
                        math.clamp(currentTheme.ElementColor.B*255+20,0,255))},0.1)
                end)
                CPRow.MouseLeave:Connect(function() Tween(CPRow,{BackgroundColor3=currentTheme.ElementColor},0.1) end)

                CPRow.MouseButton1Click:Connect(function()
                    if pickerWindowRef then
                        pickerWindowRef:Destroy(); pickerWindowRef = nil
                        Tween(CPRow,{BackgroundColor3=currentTheme.ElementColor, BackgroundTransparency=0.3},0.15)
                        return
                    end
                    Tween(CPRow,{BackgroundColor3=currentTheme.SchemeColor, BackgroundTransparency=0.1},0.15)
                    local pw = CreateColorPickerWindow(ScreenGui, currentTheme, currentColor, name)
                    local bpos = CPRow.AbsolutePosition
                    local ssize = ScreenGui.AbsoluteSize
                    local px = math.clamp(bpos.X + 10, 10, ssize.X - 320)
                    local py = math.clamp(bpos.Y - 160, 10, ssize.Y - 326)
                    for _,v in ipairs(ScreenGui:GetChildren()) do
                        if v.Name=="ColorPickerWindow" and v:IsA("Frame") then
                            v.Position = UDim2.fromOffset(px, py)
                        end
                    end
                    pickerWindowRef = pw
                    pw.OnColorChanged = function(color)
                        currentColor = color
                        CPPreview.BackgroundColor3 = color
                        HexLabel.Text = colorToHex(color)
                        if callback then callback(color) end
                    end
                    pw.OnClose = function()
                        pickerWindowRef = nil
                        Tween(CPRow,{BackgroundColor3=currentTheme.ElementColor, BackgroundTransparency=0.3},0.15)
                    end
                end)

                CPFrame.Parent = SectionContent

                local cpObj = {Frame=CPFrame}
                function cpObj:Set(color)
                    if typeof(color)~="Color3" then return end
                    currentColor = color
                    CPPreview.BackgroundColor3 = color
                    HexLabel.Text = colorToHex(color)
                    if pickerWindowRef then pickerWindowRef:SetColor(color) end
                    if callback then callback(color) end
                end
                function cpObj:Get() return currentColor end
                return cpObj
            end

            return SectionFunctions
        end

        return TabFunctions
    end

    return {
        AddTab = SimpleKavo.AddTab,
        ToggleUI = function()
            ScreenGui.Enabled = not ScreenGui.Enabled
        end,
        Destroy = function()
            ScreenGui:Destroy()
        end,
        Minimize = function()
            Minimized = not Minimized
            if Minimized then Tween(Main, {Size=UDim2.new(0,0,0,0)})
            else Tween(Main, {Size=UDim2.new(0,500,0,370)}) end
        end,
        ChangeTheme = function(newThemeName)
            updateTheme(newThemeName)
        end
    }
end

return SimpleKavo
