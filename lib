        task.defer(updateArrows)
    end)

    local function getSortedTabButtons()
        local buttons = {}
        for _, child in ipairs(TabsHolder:GetChildren()) do
            if child:IsA("TextButton") then
                table.insert(buttons, child)
            end
        end
        table.sort(buttons, function(a, b)
            return a.LayoutOrder < b.LayoutOrder
        end)
        return buttons
    end

    local function scrollToNextTab(direction)
        local scrollX = TabsScroll.CanvasPosition.X
        local visibleSize = TabsScroll.AbsoluteSize.X
        local visibleEnd = scrollX + visibleSize
        local buttons = getSortedTabButtons()

        if direction == 1 then
            for _, btn in ipairs(buttons) do
                local btnLocalEnd = (btn.AbsolutePosition.X - TabsScroll.AbsolutePosition.X) + scrollX + btn.AbsoluteSize.X
                if btnLocalEnd > visibleEnd + 1 then
                    local newX = math.max(0, btnLocalEnd - visibleSize)
                    Tween(TabsScroll, {CanvasPosition = Vector2.new(newX, 0)}, 0.25)
                    return
                end
            end
        else
            for i = #buttons, 1, -1 do
                local btn = buttons[i]
                local btnLocalStart = (btn.AbsolutePosition.X - TabsScroll.AbsolutePosition.X) + scrollX
                if btnLocalStart < scrollX - 1 then
                    local newX = math.max(0, btnLocalStart)
                    Tween(TabsScroll, {CanvasPosition = Vector2.new(newX, 0)}, 0.25)
                    return
                end
            end
            Tween(TabsScroll, {CanvasPosition = Vector2.new(0, 0)}, 0.25)
        end
    end

