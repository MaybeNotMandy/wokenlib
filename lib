    local function updateWheelTrackColor()
        ValTrack.BackgroundColor3 = Color3.fromHSV(obj.hue, obj.sat, 1)
    end

    local function updateCursors(animDur)
        local d = animDur or 0
        local radius = obj.sat / 2
        local theta  = (obj.hue * math.pi * 2) - (math.pi * 2)
        local cx, cy = polarToCart(radius, theta)
        local newWheelPos = UDim2.fromScale(cx + 0.5, cy + 0.5)
        if d > 0 then Tween(WheelCursor, {Position = newWheelPos}, d)
        else WheelCursor.Position = newWheelPos end
        local newValPos = UDim2.fromScale(obj.val, 0)
        if d > 0 then Tween(ValCursor, {Position = newValPos}, d)
        else ValCursor.Position = newValPos end
    end

    local function updateRGBSliders()
        local r,g,b = obj.color.R, obj.color.G, obj.color.B
        local vals = {r,g,b}
        for i=1,3 do
            local pct = vals[i]
            Tween(rgbFills[i].fill, {Size = UDim2.fromScale(pct,1)}, 0.12)
            rgbVals[i].Text = tostring(math.floor(pct * 255))
        end
    end

    local function displayHSV(moveCursors)
        obj.color = Color3.fromHSV(obj.hue, obj.sat, obj.val)
        updateWheelTrackColor()
        updateRGBSliders()
        if moveCursors then updateCursors(0.15) end
        if obj.OnColorChanged then obj.OnColorChanged(obj.color) end
    end

    local function displayRGB()
        local h,s,v = obj.color:ToHSV()
        obj.hue = h; obj.sat = s; obj.val = v
        updateWheelTrackColor()
        updateRGBSliders()
        updateCursors(0.15)
        if obj.OnColorChanged then obj.OnColorChanged(obj.color) end
    end

    local wheelDcon, wheelAcon
    local wheelTargetPos = WheelCursor.Position
    local center = Vector2.new(0.5, 0.5)

    ColorWheel.InputBegan:Connect(function(io)
        if io.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        obj.pickerMoving = true
        local pickerPos   = ColorWheel.AbsolutePosition
        local pickerWidth = ColorWheel.AbsoluteSize.X

        local function processInput(pos)
            local x = (pos.X - pickerPos.X) / pickerWidth
            local y = (pos.Y - pickerPos.Y) / pickerWidth
            local radius, theta = cartToPolar(x-0.5, y-0.5)
            local centerMag = (Vector2.new(x,y) - center).Magnitude
            if centerMag > 0.5 then
                x,y = polarToCart(radius-(centerMag-0.5), theta)
                x+=0.5; y+=0.5
                centerMag = (Vector2.new(x,y)-center).Magnitude
            end
            wheelTargetPos = UDim2.fromScale(x,y)
            obj.hue = ((theta/math.pi + 2) / 2) % 1
            obj.sat = math.clamp(centerMag*2, 0, 1)
            displayHSV(false)
        end

        processInput(io.Position)
        if wheelAcon then wheelAcon:Disconnect() end
        wheelAcon = RunService.RenderStepped:Connect(function(dt)
            WheelCursor.Position = WheelCursor.Position:Lerp(wheelTargetPos, 1-1e-12^dt)
        end)
        if wheelDcon then wheelDcon:Disconnect() end
        wheelDcon = UserInputService.InputChanged:Connect(function(io2)
            if io2.UserInputType == Enum.UserInputType.MouseMovement then
                processInput(io2.Position)
            end
        end)
    end)
    ColorWheel.InputEnded:Connect(function(io)
        if io.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        obj.pickerMoving = false
        if wheelDcon then wheelDcon:Disconnect() end
        if wheelAcon then wheelAcon:Disconnect() end
        Tween(WheelCursor, {Position = wheelTargetPos}, 0.12)
    end)

    local valDcon, valAcon
    local valTargetPos = ValCursor.Position

    ValTrack.InputBegan:Connect(function(io)
        if io.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        local trackPos   = ValTrack.AbsolutePosition
        local trackWidth = ValTrack.AbsoluteSize.X

        local function processVal(pos)
            local pct = math.clamp((pos.X - trackPos.X)/trackWidth, 0, 1)
            valTargetPos = UDim2.fromScale(pct, 0)
            obj.val = pct
            displayHSV(false)
        end

        processVal(io.Position)
        if valAcon then valAcon:Disconnect() end
        valAcon = RunService.RenderStepped:Connect(function(dt)
            ValCursor.Position = ValCursor.Position:Lerp(valTargetPos, 1-1e-12^dt)
        end)
        if valDcon then valDcon:Disconnect() end
        valDcon = UserInputService.InputChanged:Connect(function(io2)
            if io2.UserInputType == Enum.UserInputType.MouseMovement then processVal(io2.Position) end
        end)
    end)
    ValTrack.InputEnded:Connect(function(io)
        if io.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        if valDcon then valDcon:Disconnect() end
        if valAcon then valAcon:Disconnect() end
        Tween(ValCursor, {Position = valTargetPos}, 0.12)
    end)
    ValTrack.MouseEnter:Connect(function() Tween(VTStroke, {Transparency=0.4}, 0.1) end)
    ValTrack.MouseLeave:Connect(function() Tween(VTStroke, {Transparency=0.75}, 0.1) end)

    for i=1,3 do
        local ch    = rgbFills[i]
        local track = ch.track
        local fill  = ch.fill
        local rgbDcon, rgbAcon
        local rgbTargetSize = fill.Size

        local function processRGB(pos)
            local tp   = track.AbsolutePosition
            local tw   = track.AbsoluteSize.X
            local pct  = math.clamp((pos.X - tp.X)/tw, 0, 1)
            rgbTargetSize = UDim2.fromScale(pct, 1)
            rgbVals[i].Text = tostring(math.floor(pct*255))
            local r = (i==1) and pct or obj.color.R
            local g = (i==2) and pct or obj.color.G
            local b = (i==3) and pct or obj.color.B
            obj.color = Color3.new(r,g,b)
            displayRGB()
        end

        track.InputBegan:Connect(function(io)
            if io.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
            processRGB(io.Position)
            if rgbAcon then rgbAcon:Disconnect() end
            rgbAcon = RunService.RenderStepped:Connect(function(dt)
                fill.Size = fill.Size:Lerp(rgbTargetSize, 1-1e-12^dt)
            end)
            if rgbDcon then rgbDcon:Disconnect() end
            rgbDcon = UserInputService.InputChanged:Connect(function(io2)
                if io2.UserInputType == Enum.UserInputType.MouseMovement then processRGB(io2.Position) end
            end)
        end)
        track.InputEnded:Connect(function(io)
            if io.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
            if rgbDcon then rgbDcon:Disconnect() end
            if rgbAcon then rgbAcon:Disconnect() end
            Tween(fill, {Size = rgbTargetSize}, 0.12)
        end)
    end

    local speedDcon, speedAcon
    local speedTargetPos = SpeedCursor.Position
    SpeedCursor.Position = UDim2.fromScale(0, 1 - obj.chromaSpeed)

    SpeedTrack.InputBegan:Connect(function(io)
        if io.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        local tp = SpeedTrack.AbsolutePosition
        local th = SpeedTrack.AbsoluteSize.Y
        local function processSpeed(pos)
            local pct = math.clamp((pos.Y - tp.Y)/th, 0, 1)
            speedTargetPos = UDim2.fromScale(0, pct)
            obj.chromaSpeed = 1 - pct
        end
        processSpeed(io.Position)
        if speedAcon then speedAcon:Disconnect() end
        speedAcon = RunService.RenderStepped:Connect(function(dt)
            SpeedCursor.Position = SpeedCursor.Position:Lerp(speedTargetPos, 1-1e-12^dt)
        end)
        if speedDcon then speedDcon:Disconnect() end
        speedDcon = UserInputService.InputChanged:Connect(function(io2)
            if io2.UserInputType == Enum.UserInputType.MouseMovement then processSpeed(io2.Position) end
        end)
    end)
    SpeedTrack.InputEnded:Connect(function(io)
        if io.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        if speedDcon then speedDcon:Disconnect() end
        if speedAcon then speedAcon:Disconnect() end
        Tween(SpeedCursor, {Position = speedTargetPos}, 0.12)
    end)

    local function setChroma(enabled)
        obj.chromaEnabled = enabled
        if enabled then
            ChromaIcon.Image = "rbxassetid://9840988620"
            Tween(ChromaBtn, {BackgroundColor3 = theme.SchemeColor, BackgroundTransparency=0.05}, 0.15)
            Tween(ChromaIcon, {Rotation=360}, 0.5)
            Tween(SpeedSlider, {Position = UDim2.new(0,6,1,-24)}, 0.3)
            if obj.chromaCon then obj.chromaCon:Disconnect() end
            obj.chromaCon = RunService.RenderStepped:Connect(function(dt)
                if obj.pickerMoving then return end
                dt = dt * obj.chromaSpeed
                obj.hue = (obj.hue + dt) % 1
                displayHSV(true)
            end)
        else
            ChromaIcon.Image = "rbxassetid://9841673199"
            Tween(ChromaBtn, {BackgroundColor3 = theme.ElementColor, BackgroundTransparency=0.2}, 0.15)
            Tween(ChromaIcon, {Rotation=0}, 0.5)
            Tween(SpeedSlider, {Position = UDim2.new(0,-42,1,-24)}, 0.3)
            if obj.chromaCon then obj.chromaCon:Disconnect(); obj.chromaCon = nil end
        end
        if obj.OnChroma then obj.OnChroma(enabled) end
    end

    ChromaBtn.MouseEnter:Connect(function()
        if not obj.chromaEnabled then
            Tween(ChromaBtn, {BackgroundTransparency=0.05}, 0.1)
        end
    end)
    ChromaBtn.MouseLeave:Connect(function()
        if not obj.chromaEnabled then
            Tween(ChromaBtn, {BackgroundTransparency=0.2}, 0.1)
        end
    end)
    ChromaBtn.MouseButton1Click:Connect(function()
        setChroma(not obj.chromaEnabled)
    end)

    BtnMin.MouseEnter:Connect(function()
        obj.minFocused = true
        Tween(BtnMin, {BackgroundColor3 = obj.minimized and theme.SchemeColor or theme.ElementColor, BackgroundTransparency=0.05}, 0.1)
    end)
    BtnMin.MouseLeave:Connect(function()
        obj.minFocused = false
        Tween(BtnMin, {BackgroundColor3 = theme.ElementColor, BackgroundTransparency=0.3}, 0.1)
    end)
    BtnMin.MouseButton1Click:Connect(function()
        obj.minimized = not obj.minimized
        if obj.minimized then
            Tween(Main, {Size = UDim2.fromOffset(310,30)}, 0.3)
            BtnMinIcon.Image = "rbxassetid://9642646619"
            Tween(BtnMinIcon, {Rotation=45, ImageColor3=theme.SchemeColor}, 0.3)
            Region.Visible = false
        else
            Tween(Main, {Size = UDim2.fromOffset(310,316)}, 0.3)
            BtnMinIcon.Image = "rbxassetid://9642680675"
            Tween(BtnMinIcon, {Rotation=0, ImageColor3=Color3.fromRGB(255,255,255)}, 0.3)
            Region.Visible = true
        end
    end)

    BtnClose.MouseEnter:Connect(function() Tween(BtnClose,{BackgroundColor3=Color3.fromRGB(200,50,50),BackgroundTransparency=0.1},0.1) end)
    BtnClose.MouseLeave:Connect(function() Tween(BtnClose,{BackgroundColor3=theme.ElementColor,BackgroundTransparency=0.3},0.1) end)
    BtnClose.MouseButton1Click:Connect(function() obj:Destroy() end)

    SimpleKavo:DraggingEnabled(Header, Main)

    task.spawn(function()
        Main.Size = UDim2.fromOffset(310, 32)
        Tween(Main, {Size = UDim2.fromOffset(310, 316)}, 0.45)
        local offsetU = UDim2.fromOffset(40,0)
        BtnClose.Position = BtnClose.Position + offsetU
        BtnMin.Position   = BtnMin.Position   + offsetU
        HeaderIcon.Position = HeaderIcon.Position - offsetU
        TitleLbl.Position   = TitleLbl.Position   - offsetU
        Tween(BtnClose,   {Position = BtnClose.Position   - offsetU}, 0.6)
        Tween(BtnMin,     {Position = BtnMin.Position     - offsetU}, 0.6)
        Tween(HeaderIcon, {Position = HeaderIcon.Position + offsetU}, 0.6)
        Tween(TitleLbl,   {Position = TitleLbl.Position   + offsetU}, 0.6)
        Tween(Fade, {BackgroundTransparency=1}, 1.2)
        task.wait(1.2); Fade.Visible = false
    end)

    displayHSV(false)
    updateCursors(0)

    function obj:SetColor(c3)
        if typeof(c3) ~= "Color3" then return end
        self.color = c3
        self.hue, self.sat, self.val = c3:ToHSV()
        displayHSV(true)
    end

    function obj:GetColor()
        return self.color
    end

    function obj:Destroy()
        if obj.chromaCon then obj.chromaCon:Disconnect() end
        if obj.OnClose then obj.OnClose() end
        task.spawn(function()
            local desc = Main:GetDescendants()
            table.insert(desc, Main)
            local frames={} local imgs={} local texts={} local strokes={}
            for _,v in ipairs(desc) do
                local c = v.ClassName
                if c=="Frame" or c=="ScrollingFrame" then table.insert(frames,v)
                elseif c=="ImageLabel" or c=="ImageButton" then table.insert(imgs,v)
                elseif c=="TextLabel" or c=="TextButton" or c=="TextBox" then table.insert(texts,v)
                elseif c=="UIStroke" then table.insert(strokes,v) end
            end
            local animCon = RunService.RenderStepped:Connect(function(dt)
                dt = dt * 6
                for _,v in ipairs(frames)  do v.BackgroundTransparency = math.min(v.BackgroundTransparency+dt,1) end
                for _,v in ipairs(imgs)    do v.ImageTransparency       = math.min(v.ImageTransparency+dt,1)     end
                for _,v in ipairs(texts)   do v.TextTransparency        = math.min(v.TextTransparency+dt,1)      end
            end)
            for _,v in ipairs(strokes) do v.Transparency = 1 end
            Tween(UIScale, {Scale=0.65}, 0.4)
            task.wait(0.42)
            animCon:Disconnect()
            Main:Destroy()
        end)
    end

    return obj
end

